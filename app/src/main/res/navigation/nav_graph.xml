<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/splashFragment">

    <fragment
        android:id="@+id/splashFragment"
        android:name="com.example.admobnextgensdk.ui.splash.SplashFragment"
        android:label="Splash"
        tools:layout="@layout/fragment_splash">
        <action
            android:id="@+id/action_splash_to_onboarding1"
            app:destination="@id/onboarding1Fragment"
            app:popUpTo="@id/splashFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/onboarding1Fragment"
        android:name="com.example.admobnextgensdk.ui.boarding.Onboarding1Fragment"
        android:label="Onboarding 1"
        tools:layout="@layout/fragment_onboarding1">
        <action
            android:id="@+id/action_onboarding1_to_onboarding2"
            app:destination="@id/onboarding2Fragment" />
    </fragment>

    <fragment
        android:id="@+id/onboarding2Fragment"
        android:name="com.example.admobnextgensdk.ui.boarding.Onboarding2Fragment"
        android:label="Onboarding 2"
        tools:layout="@layout/fragment_onboarding2">
        <!-- Navigate to full-screen native if ad is ready -->
        <action
            android:id="@+id/action_onboarding2_to_fullscreen_native"
            app:destination="@id/fullScreenNativeFragment" />
        <!-- Skip directly to Onboarding3 if no ad available -->
        <action
            android:id="@+id/action_onboarding2_to_onboarding3"
            app:destination="@id/onboarding3Fragment" />
    </fragment>

    <fragment
        android:id="@+id/fullScreenNativeFragment"
        android:name="com.example.admobnextgensdk.ui.boarding.FullScreenNativeFragment"
        android:label="Full Screen Native"
        tools:layout="@layout/fragment_fullscreen_native">
        <action
            android:id="@+id/action_fullscreen_native_to_onboarding3"
            app:destination="@id/onboarding3Fragment" />
    </fragment>

    <fragment
        android:id="@+id/onboarding3Fragment"
        android:name="com.example.admobnextgensdk.ui.boarding.Onboarding3Fragment"
        android:label="Onboarding 3"
        tools:layout="@layout/fragment_onboarding3">
        <action
            android:id="@+id/action_onboarding3_to_home"
            app:destination="@id/homeFragment"
            app:popUpTo="@id/onboarding1Fragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.example.admobnextgensdk.ui.home.HomeFragment"
        android:label="Home"
        tools:layout="@layout/fragment_home">
        <action
            android:id="@+id/action_home_to_home1"
            app:destination="@id/homeFragment1" />
        <action
            android:id="@+id/action_home_to_home2"
            app:destination="@id/homeFragment2" />
        <action
            android:id="@+id/action_home_to_home3"
            app:destination="@id/homeFragment3" />
    </fragment>

    <fragment
        android:id="@+id/homeFragment1"
        android:name="com.example.admobnextgensdk.ui.home.HomeFragment1"
        android:label="Home 1"
        tools:layout="@layout/fragment_home1" />

    <fragment
        android:id="@+id/homeFragment2"
        android:name="com.example.admobnextgensdk.ui.home.HomeFragment2"
        android:label="Home 2"
        tools:layout="@layout/fragment_home2" />

    <fragment
        android:id="@+id/homeFragment3"
        android:name="com.example.admobnextgensdk.ui.home.HomeFragment3"
        android:label="Home 3"
        tools:layout="@layout/fragment_home3" />

</navigation>
